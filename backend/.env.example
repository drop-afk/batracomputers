MONGODB_URI=mongodb://localhost:27017/batra_booking
FRONTEND_URL=http://localhost:3000
PORT=5000

# Temporary: show signup OTPs on the verification screen.
# Set to false after SMTP and WhatsApp delivery are configured.
DISPLAY_SIGNUP_OTP=true
OTP_DEV_MODE=false

# Future email OTP delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Future WhatsApp OTP delivery.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_API_VERSION=v23.0

# Create Test Mode keys in Razorpay Dashboard first, then replace with Live Mode keys.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
